// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(CUSTOMER)
  createdAt DateTime @default(now())

  reviews   Review[]
  orders    Order[]
  favorites Favorite[]
}

enum Role {
  CUSTOMER
  ADMIN
}

model Product {
  id            String @id @default(uuid())
  name          String
  slug          String @unique
  price         Float
  discountPrice Float?
  stock         Int

  brandId String?
  brand   Brand?  @relation(fields: [brandId], references: [id])

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  typeId String
  type   ProductType @relation(fields: [typeId], references: [id], onDelete: Restrict)

  details     String?
  description String?
  images      ProductImage[]
  sizes       ProductSize[]
  colors      ProductColor[]

  ratingAverage Float    @default(0)
  reviewCount   Int      @default(0)
  createdAt     DateTime @default(now())

  reviews    Review[]
  orderItems OrderItem[]
  favorites  Favorite[]
}

model Brand {
  id       String    @id @default(uuid())
  name     String    @unique
  imageUrl String
  products Product[]
}

model Category {
  id       String    @id @default(uuid())
  name     String    @unique // men, women, kids, accessories
  products Product[]
}

model ProductType {
  id       String    @id @default(uuid())
  name     String    @unique
  products Product[]
}

model ProductImage {
  id        String  @id @default(uuid())
  url       String
  productId String
  product   Product @relation(fields: [productId], references: [id])
}

model ProductSize {
  id        String  @id @default(uuid())
  size      String
  stock     Int
  productId String
  product   Product @relation(fields: [productId], references: [id])
}

model ProductColor {
  id        String  @id @default(uuid())
  color     String
  productId String
  stock     Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Review {
  id        String   @id @default(uuid())
  rating    Int
  comment   String
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])
}

model Favorite {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
}

model Order {
  id        String      @id @default(uuid())
  total     Float
  status    OrderStatus @default(PENDING)
  createdAt DateTime    @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  items OrderItem[]
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

model OrderItem {
  id       String @id @default(uuid())
  quantity Int
  price    Float

  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])
}
